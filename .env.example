# Core
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chatops
PROMETHEUS_BASE_URL=http://localhost:9090
LOKI_BASE_URL=http://localhost:3100

# Auth
AUTH_ENABLED=true
API_KEY=change-me

# HTTP hardening
HTTP_MAX_RETRIES=2
HTTP_RETRY_BACKOFF_SECONDS=0.3

# Logging
LOG_LEVEL=INFO

# LLM (hybrid mode)
LLM_ENABLED=true
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
LLM_TIMEOUT_SECONDS=12
LLM_TEMPERATURE=0.1

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
